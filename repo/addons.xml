<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.xtream.iptv.ultimate"
       name="Xtream IPTV Ultimate Repository"
       version="1.0.1"
       provider-name="Sui">
    <extension point="xbmc.addon.repository"
               name="Xtream IPTV Ultimate Repository">
        <dir>
            <info compressed="false">https://tktk92.github.io/Xtream-IPTV-Ultimate/repo/addons.xml</info>
            <checksum>https://tktk92.github.io/Xtream-IPTV-Ultimate/repo/addons.xml.md5</checksum>
            <datadir zip="true">https://tktk92.github.io/Xtream-IPTV-Ultimate/repo/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="de_DE">Repository fuer Xtream IPTV Ultimate</summary>
        <description lang="de_DE">Kodi Repository fuer Installation und Updates von Xtream IPTV Ultimate.</description>
        <platform>all</platform>
    </extension>
</addon>
<addon id="plugin.video.xtream.strm"
       name="Xtream IPTV Ultimate"
       version="1.0.19"
       provider-name="Sui">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.service" library="service.py" start="startup"/>

    <extension point="xbmc.addon.metadata">
        <summary lang="de_DE">Xtream IPTV Inhalte als Kodi-Bibliothek nutzen</summary>
        <description lang="de_DE">Erstellt und verwaltet Filme und Serien aus legalen Xtream IPTV-Zugaengen als Kodi-Bibliothek.</description>
        <platform>all</platform>
    </extension>
</addon>
</addons>
